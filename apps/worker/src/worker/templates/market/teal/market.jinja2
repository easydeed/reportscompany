{% extends '_base/base.jinja2' %}

{% block fonts %}
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
{% endblock %}

{% block theme_styles %}
:root {
  --primary-color: {{ user_primary_color | default('#18235c', true) }};
  --accent-color: {{ theme_color | default('#0d9488', true) }};
  --accent-on-dark: {{ theme_color_on_dark | default('#5eead4', true) }};
  --accent-on-light: {{ theme_color_on_light | default('#0f766e', true) }};
  --accent-light: {{ theme_color_light | default('#ccfbf1', true) }};
  --header-bg: linear-gradient(135deg, {{ user_primary_color | default('#18235c', true) }} 0%, #1e3a5f 60%, {{ theme_color | default('#0d9488', true) }} 100%);
  --bg-subtle: #f8fafc;
  --border-color: #e2e8f0;
  --font-display: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  --font-body: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
}
{% endblock %}
