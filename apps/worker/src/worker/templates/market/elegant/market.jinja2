{% extends '_base/base.jinja2' %}

{% block fonts %}
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
{% endblock %}

{% block theme_styles %}
:root {
  --primary-color: {{ user_primary_color | default('#1a1a1a', true) }};
  --accent-color: {{ theme_color | default('#8B2252', true) }};
  --accent-on-dark: {{ theme_color_on_dark | default('#c27595', true) }};
  --accent-on-light: {{ theme_color_on_light | default('#6e1a40', true) }};
  --accent-light: {{ theme_color_light | default('#f5dce6', true) }};
  --header-bg: linear-gradient(135deg, {{ user_primary_color | default('#1a1a1a', true) }} 0%, #2a2535 60%, {{ theme_color | default('#8B2252', true) }} 100%);
  --bg-subtle: #f7f5f3;
  --border-color: #e3ddd6;
  --font-display: 'Cormorant Garamond', Georgia, serif;
  --font-body: 'Montserrat', system-ui, sans-serif;
}
{% endblock %}
