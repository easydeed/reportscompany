{% extends '_base/base.jinja2' %}

{% block fonts %}
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
{% endblock %}

{% block theme_styles %}
:root {
  --primary-color: {{ accent_color | default('#0d9488', true) }};
  --accent-color: {{ accent_color | default('#0d9488', true) }};
  --accent-on-dark: {{ accent_on_dark | default('#5eead4', true) }};
  --accent-on-light: {{ accent_on_light | default('#0f766e', true) }};
  --accent-light: {{ accent_light | default('#a6e4de', true) }};
  --accent-text: #ffffff;
  --header-bg: {{ primary_color | default('#18235c', true) }};
  --font-display: 'Outfit', 'Inter', sans-serif;
  --font-body: 'Inter', system-ui, -apple-system, sans-serif;
}
{% endblock %}
