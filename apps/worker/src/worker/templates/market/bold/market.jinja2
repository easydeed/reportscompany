{% extends '_base/base.jinja2' %}

{% block fonts %}
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&family=Libre+Baskerville:wght@400;700&display=swap" rel="stylesheet">
{% endblock %}

{% block theme_styles %}
:root {
  --primary-color: #1B365D;
  --accent-color: {{ theme_color | default('#D4A853', true) }};
  --accent-on-dark: {{ theme_color_on_dark | default('#D4A853', true) }};
  --accent-on-light: {{ theme_color_on_light | default('#9e7a2e', true) }};
  --accent-light: {{ theme_color_light | default('#fdf3d8', true) }};
  --header-bg: linear-gradient(135deg, #1B365D 0%, #1f4268 60%, {{ theme_color | default('#D4A853', true) }} 100%);
  --bg-light: #f5f3ef;
  --border-color: #e0dcd4;
  --font-display: 'Montserrat', system-ui, sans-serif;
  --font-body: 'Libre Baskerville', Georgia, serif;
}
{% endblock %}
