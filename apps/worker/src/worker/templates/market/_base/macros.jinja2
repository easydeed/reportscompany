{# =============================================================================
   MARKET REPORT MACROS — V0 Final Design System
   Reusable components for all 4 market report layouts.
   ============================================================================= #}


{# ── Report Header ─────────────────────────────────────────────────────────── #}
{% macro report_header(header, report_type, agent) %}
<header class="report-header">
  <div class="header-left">
    <h1 class="header-title">{{ header.title | default('Market Report') }} <span>&mdash; {{ header.city | default('') }}</span></h1>
    <p class="header-subtitle">
      Last <span>{{ header.lookback_days | default(30) }} days</span> &middot; {{ header.subtitle if header.subtitle else 'All Properties' }} &middot; Live MLS Data
    </p>
    {% if header.total_count is defined and header.total_count %}
    <div class="header-metric">
      <span class="header-metric-value">{{ header.total_count }}</span>
      <span class="header-metric-label">{{ header.title | default('Listings') }}</span>
    </div>
    {% endif %}
  </div>
  <div class="header-right">
    {% if agent and agent.logo_url %}
    <img class="header-logo" src="{{ agent.logo_url }}" alt="">
    {% endif %}
  </div>
</header>
{% endmacro %}


{# ── Gallery Layout (A): new_listings_gallery, featured_listings, open_houses #}
{% macro gallery_layout(header, listings, stats, report_type, agent, ai_narrative=none) %}
<div class="count-bar">
  <div class="count-circle">{{ header.total_count | default(0) }}</div>
  <div>
    <div class="count-label">{{ header.title | default('Listings') }}</div>
    {% if header.subtitle %}<div class="count-sublabel">{{ header.subtitle }}</div>{% endif %}
  </div>
  <div class="count-divider"></div>
</div>

{% if ai_narrative %}
<div class="ai-narrative avoid-break">
  <div class="ai-narrative-label">AI Market Insight</div>
  <p class="ai-narrative-text">{{ ai_narrative }}</p>
</div>
{% endif %}

{% if listings %}
<div class="gallery-grid">
  {% for listing in listings[:6] %}
  <div class="listing-card avoid-break">
    <div class="listing-photo{% if not listing.photo_url %} no-image{% endif %}"{% if listing.photo_url %} style="background-image: url('{{ listing.photo_url }}');"{% endif %}>
      {% if report_type == 'featured_listings' %}
      <span class="listing-status featured">Featured</span>
      {% elif report_type == 'open_houses' %}
      <span class="listing-status">Open House</span>
      {% elif report_type == 'new_listings_gallery' %}
      <span class="listing-status">New</span>
      {% endif %}
    </div>
    <div class="listing-info">
      <div class="listing-price">{% if listing.list_price %}{{ listing.list_price | format_currency }}{% else %}&mdash;{% endif %}</div>
      <div class="listing-address">{{ listing.address | default('Address unavailable') | truncate(40) }}</div>
      <div class="listing-details">
        {% if listing.beds %}<span class="listing-detail"><strong>{{ listing.beds }}</strong> bd</span>{% endif %}
        {% if listing.baths %}<span class="listing-detail"><strong>{{ listing.baths }}</strong> ba</span>{% endif %}
        {% if listing.sqft %}<span class="listing-detail"><strong>{{ listing.sqft | format_number }}</strong> sf</span>{% endif %}
      </div>
    </div>
  </div>
  {% endfor %}
</div>
{% else %}
<div class="gallery-grid">
  <p style="grid-column:1/-1;text-align:center;color:var(--gray-500);padding:2in 0;font-size:11px;">No listings found for this period.</p>
</div>
{% endif %}
{% endmacro %}


{# ── Market Narrative Layout (B): market_snapshot ───────────────────────────── #}
{% macro market_narrative_layout(header, listings, stats, report_type, agent, ai_insights=none, ai_narrative=none) %}
<div class="hero-stat avoid-break">
  <div class="hero-stat-value">{% if stats.median_list_price %}{{ stats.median_list_price | format_currency }}{% else %}&mdash;{% endif %}</div>
  <div class="hero-stat-label">Median Sale Price</div>
</div>

{% if ai_narrative or ai_insights %}
<div class="ai-narrative avoid-break">
  <div class="ai-narrative-label">AI Market Insight</div>
  <p class="ai-narrative-text">{{ ai_narrative or ai_insights }}</p>
</div>
{% endif %}

{% if listings %}
<div class="photo-grid avoid-break">
  {% for listing in listings[:4] %}
  <div class="photo-grid-item"{% if listing.photo_url %} style="background-image: url('{{ listing.photo_url }}');"{% endif %}>
    <div class="photo-overlay">
      <div class="photo-overlay-price">{% if listing.list_price %}{{ listing.list_price | format_currency }}{% endif %}</div>
      <div class="photo-overlay-address">{{ listing.address | default('') | truncate(28) }}</div>
    </div>
  </div>
  {% endfor %}
</div>
{% endif %}

<div class="stats-bar avoid-break">
  {% if stats.avg_dom %}
  <div class="stats-bar-row">
    <span class="stats-bar-label">Avg Days on Market</span>
    <span class="stats-bar-value">{{ stats.avg_dom }}</span>
  </div>
  {% endif %}
  {% if stats.months_of_inventory %}
  <div class="stats-bar-row">
    <span class="stats-bar-label">Months of Inventory</span>
    <span class="stats-bar-value">{{ stats.months_of_inventory }}</span>
  </div>
  {% endif %}
  {% if stats.price_per_sqft %}
  <div class="stats-bar-row">
    <span class="stats-bar-label">Price per Sq Ft</span>
    <span class="stats-bar-value">${{ stats.price_per_sqft | format_number }}</span>
  </div>
  {% endif %}
  {% if stats.list_to_sale_ratio %}
  <div class="stats-bar-row">
    <span class="stats-bar-label">List-to-Sale Ratio</span>
    <span class="stats-bar-value">{{ "%.1f" | format(stats.list_to_sale_ratio * 100 if stats.list_to_sale_ratio < 2 else stats.list_to_sale_ratio) }}%</span>
  </div>
  {% endif %}
</div>

{% endmacro %}


{# ── Closed / Inventory Layout (C): closed, inventory ─────────────────────── #}
{% macro closed_inventory_layout(header, listings, stats, report_type, agent, ai_insights=none, ai_narrative=none) %}
<div class="hero-stat-row avoid-break">
  <div class="hero-stat-left">
    {% if report_type == 'closed' %}
    <div class="hero-stat-value">{% if stats.median_close_price %}{{ stats.median_close_price | format_currency }}{% elif stats.median_list_price %}{{ stats.median_list_price | format_currency }}{% else %}{{ stats.closed_count | default(0) }}{% endif %}</div>
    <div class="hero-stat-label">{% if stats.median_close_price or stats.median_list_price %}Median Sale Price{% else %}Homes Sold{% endif %}</div>
    {% else %}
    <div class="hero-stat-value">{{ stats.active_count | default(0) }}</div>
    <div class="hero-stat-label">Active Listings</div>
    {% endif %}
  </div>
  <div class="hero-stat-right">
    {% if stats.avg_dom %}
    <div class="mini-stat">
      <div class="mini-stat-value">{{ stats.avg_dom }}</div>
      <div class="mini-stat-label">Avg DOM</div>
    </div>
    {% endif %}
    {% if stats.months_of_inventory %}
    <div class="mini-stat">
      <div class="mini-stat-value">{{ stats.months_of_inventory }}</div>
      <div class="mini-stat-label">Mo. Supply</div>
    </div>
    {% endif %}
    {% if stats.price_per_sqft %}
    <div class="mini-stat">
      <div class="mini-stat-value">${{ stats.price_per_sqft | format_number }}</div>
      <div class="mini-stat-label">$/Sq Ft</div>
    </div>
    {% endif %}
    {% if stats.list_to_sale_ratio %}
    <div class="mini-stat">
      <div class="mini-stat-value">{{ "%.1f" | format(stats.list_to_sale_ratio * 100 if stats.list_to_sale_ratio < 2 else stats.list_to_sale_ratio) }}%</div>
      <div class="mini-stat-label">Sale Ratio</div>
    </div>
    {% endif %}
  </div>
</div>

{% if listings %}
<div class="photo-grid avoid-break">
  {% for listing in listings[:4] %}
  <div class="photo-grid-item"{% if listing.photo_url %} style="background-image: url('{{ listing.photo_url }}');"{% endif %}>
    {% if listing.status %}
    <span class="photo-badge {{ listing.status | lower }}">{{ listing.status }}</span>
    {% endif %}
    <div class="photo-overlay">
      <div class="photo-overlay-price">{% if report_type == 'closed' and listing.close_price %}{{ listing.close_price | format_currency }}{% elif listing.list_price %}{{ listing.list_price | format_currency }}{% endif %}</div>
      <div class="photo-overlay-address">{{ listing.address | default('') | truncate(28) }}</div>
    </div>
  </div>
  {% endfor %}
</div>
{% endif %}

{% if ai_narrative or ai_insights %}
<div class="ai-narrative avoid-break">
  <div class="ai-narrative-label">AI Market Insight</div>
  <p class="ai-narrative-text">{{ ai_narrative or ai_insights }}</p>
</div>
{% endif %}

{% if listings %}
<div class="data-table-section avoid-break">
  <div class="data-table-title">{% if report_type == 'closed' %}Recent Closed Sales{% else %}Active Inventory{% endif %}</div>
  <table class="data-table">
    <thead>
      <tr>
        <th>Address</th>
        <th>Bd/Ba</th>
        <th>Sq Ft</th>
        <th>Price</th>
        <th>DOM</th>
      </tr>
    </thead>
    <tbody>
      {% for l in listings[:5] %}
      <tr>
        <td class="td-address">{{ l.address | default('-') | truncate(28) }}</td>
        <td class="td-muted">{{ l.beds | default('-') }}/{{ l.baths | default('-') }}</td>
        <td class="td-muted">{% if l.sqft %}{{ l.sqft | format_number }}{% else %}-{% endif %}</td>
        <td class="td-price">{% if report_type == 'closed' and l.close_price %}{{ l.close_price | format_currency }}{% elif l.list_price %}{{ l.list_price | format_currency }}{% else %}-{% endif %}</td>
        <td class="td-muted">{{ l.days_on_market if l.days_on_market else '-' }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endif %}
{% endmacro %}


{# ── Analytics Layout (D): price_bands, new_listings ─────────────────────── #}
{% macro analytics_layout(header, listings, stats, price_bands, report_type, agent, ai_insights=none, ai_narrative=none) %}
<div class="hero-stat avoid-break">
  {% if report_type == 'price_bands' %}
  <div class="hero-stat-value">{{ header.total_count | default(0) }}</div>
  <div class="hero-stat-label">Active Listings</div>
  {% else %}
  <div class="hero-stat-value">{{ header.total_count | default(0) }}</div>
  <div class="hero-stat-label">New This Month</div>
  {% endif %}
</div>

<div class="stat-blocks avoid-break">
  {% if price_bands %}
  {% for band in price_bands[:4] %}
  <div class="stat-block{% if loop.first %} stat-block-accent{% endif %}">
    <div class="stat-block-value">{{ band.count | default(0) }}</div>
    <div class="stat-block-label">{{ band.label | default('') }}</div>
  </div>
  {% endfor %}
  {% else %}
  {% if stats.median_list_price %}
  <div class="stat-block">
    <div class="stat-block-value">{{ stats.median_list_price | format_currency_short }}</div>
    <div class="stat-block-label">Median Price</div>
  </div>
  {% endif %}
  {% if stats.avg_dom %}
  <div class="stat-block">
    <div class="stat-block-value">{{ stats.avg_dom }}</div>
    <div class="stat-block-label">Avg DOM</div>
  </div>
  {% endif %}
  {% if stats.price_per_sqft %}
  <div class="stat-block">
    <div class="stat-block-value">${{ stats.price_per_sqft | format_number }}</div>
    <div class="stat-block-label">Price / Sq Ft</div>
  </div>
  {% endif %}
  {% if stats.months_of_inventory %}
  <div class="stat-block">
    <div class="stat-block-value">{{ stats.months_of_inventory }}</div>
    <div class="stat-block-label">Months Supply</div>
  </div>
  {% endif %}
  {% endif %}
</div>

{% if ai_narrative or ai_insights %}
<div class="ai-narrative avoid-break">
  <div class="ai-narrative-label">AI Market Insight</div>
  <p class="ai-narrative-text">{{ ai_narrative or ai_insights }}</p>
</div>
{% endif %}

{% if listings %}
<div class="property-list">
  {% set tier_labels = ['Low', 'Median', 'High'] %}
  {% set tier_classes = ['tier-low', 'tier-median', 'tier-high'] %}
  {% for listing in listings[:3] %}
  <div class="property-card avoid-break">
    <div class="property-card-photo{% if not listing.photo_url %} no-image{% endif %}"{% if listing.photo_url %} style="background-image: url('{{ listing.photo_url }}');"{% endif %}>
      {% if report_type != 'new_listings' and listing.status %}
      <span class="property-card-badge">{{ listing.status }}</span>
      {% endif %}
    </div>
    <div class="property-card-info">
      {% if report_type == 'new_listings' %}
      <span class="listing-tier-badge {{ tier_classes[loop.index0] }}" style="position:absolute;top:10px;right:10px;">{{ tier_labels[loop.index0] }}</span>
      {% endif %}
      <div class="property-card-price">{% if listing.list_price %}{{ listing.list_price | format_currency }}{% else %}&mdash;{% endif %}</div>
      <div class="property-card-address">{{ listing.address | default('Address unavailable') | truncate(40) }}{% if listing.city %}, {{ listing.city }}{% endif %}</div>
      <div class="property-card-details">
        {% if listing.beds %}<span class="property-card-detail"><strong>{{ listing.beds }}</strong> beds</span>{% endif %}
        {% if listing.baths %}<span class="property-card-detail"><strong>{{ listing.baths }}</strong> baths</span>{% endif %}
        {% if listing.sqft %}<span class="property-card-detail"><strong>{{ listing.sqft | format_number }}</strong> sqft</span>{% endif %}
        {% if listing.days_on_market %}<span class="property-card-detail"><strong>{{ listing.days_on_market }}</strong> DOM</span>{% endif %}
      </div>
    </div>
  </div>
  {% endfor %}
</div>
{% else %}
<div class="property-list">
  <p style="text-align:center;color:var(--gray-500);padding:1in 0;font-size:11px;">No listings found for this period.</p>
</div>
{% endif %}
{% endmacro %}


{# ── Price Bands Layout: price_bands ──────────────────────────────────────── #}
{% macro pricebands_layout(header, listings, stats, price_bands, report_type, agent, ai_insights=none, ai_narrative=none) %}
<div class="top-row">
  <div class="hero-card">
    <div class="hero-card-value">{{ header.total_count | default(0) }}</div>
    <div class="hero-card-label">Total Active Listings</div>
  </div>
  <div class="stat-cards">
    {% if price_bands %}
    {% for band in price_bands[:4] %}
    <div class="stat-card">
      <div class="stat-card-value">{{ band.count | default(0) }}</div>
      <div class="stat-card-label">{{ band.label | default('') }}</div>
    </div>
    {% endfor %}
    {% else %}
    {% if stats.median_list_price %}
    <div class="stat-card">
      <div class="stat-card-value">{{ stats.median_list_price | format_currency_short }}</div>
      <div class="stat-card-label">Median Price</div>
    </div>
    {% endif %}
    {% if stats.avg_dom %}
    <div class="stat-card">
      <div class="stat-card-value">{{ stats.avg_dom }}</div>
      <div class="stat-card-label">Avg DOM</div>
    </div>
    {% endif %}
    {% if stats.price_per_sqft %}
    <div class="stat-card">
      <div class="stat-card-value">${{ stats.price_per_sqft | format_number }}</div>
      <div class="stat-card-label">Price / Sq Ft</div>
    </div>
    {% endif %}
    {% if stats.months_of_inventory %}
    <div class="stat-card">
      <div class="stat-card-value">{{ stats.months_of_inventory }}</div>
      <div class="stat-card-label">Months Supply</div>
    </div>
    {% endif %}
    {% endif %}
  </div>
</div>

{% if ai_narrative or ai_insights %}
<div class="pb-narrative avoid-break">
  <p>{{ ai_narrative or ai_insights }}</p>
</div>
{% endif %}

{% if listings %}
<div class="property-rows">
  {% for listing in listings[:5] %}
  <div class="property-row">
    <div class="property-photo{% if not listing.photo_url %} no-image{% endif %}">
      {% if listing.photo_url %}
      <img src="{{ listing.photo_url }}" alt="Property">
      {% endif %}
    </div>
    <div class="property-info">
      <div class="property-address">{{ listing.address | default('Address unavailable') | truncate(35) }}</div>
      <div class="property-city">{% if listing.city %}{{ listing.city }}{% endif %}</div>
    </div>
    <div class="property-details">
      <div class="property-price">{% if listing.list_price %}{{ listing.list_price | format_currency }}{% else %}&mdash;{% endif %}</div>
      <div class="property-specs">{% if listing.beds %}{{ listing.beds }} bd{% endif %}{% if listing.baths %} &bull; {{ listing.baths }} ba{% endif %}{% if listing.sqft %} &bull; {{ listing.sqft | format_number }} sqft{% endif %}</div>
    </div>
    <div class="property-status">
      {% if listing.status %}
      <span class="status-badge {{ listing.status | lower }}">{{ listing.status }}</span>
      {% endif %}
    </div>
  </div>
  {% endfor %}
</div>
{% else %}
<div class="property-rows">
  <p style="text-align:center;color:var(--gray-500);padding:1in 0;font-size:11px;">No listings found for this period.</p>
</div>
{% endif %}

{% endmacro %}


{# ── Agent Footer ─────────────────────────────────────────────────────────── #}
{% macro agent_footer(agent) %}
<div class="agent-footer">
  <div class="agent-info">
    {% if agent and agent.photo_url %}
    <img class="agent-photo" src="{{ agent.photo_url }}" alt="Agent Photo">
    {% else %}
    <div class="agent-photo-placeholder">{% if agent and agent.name %}{{ agent.name[0] | upper }}{% endif %}</div>
    {% endif %}
    <div>
      <div class="agent-name">{{ agent.name | default('') if agent else '' }}</div>
      {% if agent and agent.title %}<div class="agent-title">{{ agent.title }}</div>{% endif %}
      {% if agent and (agent.phone or agent.email) %}
      <div class="agent-contact">
        {% if agent.phone %}<span class="agent-contact-pill">{{ agent.phone }}</span>{% endif %}
        {% if agent.email %}<span class="agent-contact-pill">{{ agent.email }}</span>{% endif %}
      </div>
      {% endif %}
    </div>
  </div>
  {% if agent and agent.logo_url %}
  <img class="agent-footer-logo" src="{{ agent.logo_url }}" alt="Company Logo">
  {% endif %}
</div>
{% endmacro %}


{# ── Page Footer ──────────────────────────────────────────────────────────── #}
{% macro page_footer() %}
<div class="page-footer">
  Report generated by TrendyReports &middot; Data source: MLS
</div>
{% endmacro %}
