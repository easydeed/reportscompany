<!DOCTYPE html>
{# PDFShift native continuation header for pages 2+.
   This template renders a standalone HTML document that PDFShift's
   `header` parameter repeats on every page after page 1
   (start_at: 2 is set in tasks.py). Page 1 keeps the big inline
   gradient cover header from the report_header macro.

   IMPORTANT: PDFShift renders header/footer in a separate document
   context — CSS custom properties from the main document (--primary-color,
   etc.) do NOT resolve here. Use literal hex values passed via context.

   The {{ '{{page}}' }} / {{ '{{total}}' }} dance escapes Jinja so the
   literal `{{page}}` and `{{total}}` strings reach PDFShift's renderer,
   which then substitutes them at render time.
#}
<html>
<head>
<meta charset="utf-8">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    margin: 0;
    padding: 0;
    font-family: 'Outfit', 'Inter', system-ui, sans-serif;
    width: 8.5in;
  }
  .compact-header {
    background: linear-gradient(135deg, {{ primary_color }} 0%, {{ primary_color }} 50%, {{ accent_color }} 100%);
    padding: 10px 25px;
    color: #ffffff;
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }
  .ch-left {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .ch-title {
    font-family: 'Outfit', 'Inter', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 700;
    line-height: 1.2;
    color: #ffffff;
  }
  .ch-title-city {
    font-weight: 400;
    opacity: 0.85;
  }
  .ch-subtitle {
    font-size: 9px;
    font-weight: 400;
    color: rgba(255,255,255,0.75);
    letter-spacing: 0.02em;
  }
  .ch-subtitle-highlight {
    color: {{ accent_on_dark }};
    font-weight: 600;
  }
  .ch-right {
    font-size: 10px;
    font-weight: 500;
    color: rgba(255,255,255,0.85);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
</style>
</head>
<body>
<div class="compact-header">
  <div class="ch-left">
    <div class="ch-title">{{ report_title }} <span class="ch-title-city">— {{ city }}</span></div>
    <div class="ch-subtitle">
      Last <span class="ch-subtitle-highlight">{{ lookback_days }} days</span> · {{ subtitle_text }} · Live MLS Data
    </div>
  </div>
  <div class="ch-right">Page {{ '{{page}}' }} of {{ '{{total}}' }}</div>
</div>
</body>
</html>
