{# =============================================================================
   BASE MARKET REPORT TEMPLATE — V0 Final Design (trendy-reports.html)
   CSS copied from the V0 spec. Theme files override :root vars.
   ============================================================================= #}

{% import '_base/macros.jinja2' as macros %}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ header.title | default('Market Report') }} &mdash; {{ header.city | default('') }}</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  {% block fonts %}{% endblock %}

  <style>
    /* ============================================
       CSS CUSTOM PROPERTIES (THEMEABLE)
       ============================================ */
    :root {
      --primary-color: #18235c;
      --accent-color: #0d9488;
      --accent-light: #ccfbf1;
      --accent-on-dark: #5eead4;
      --accent-on-light: #0f766e;
      --header-bg: linear-gradient(135deg, #18235c 0%, #1e3a5f 60%, #0d9488 100%);

      --text-primary: #1f2937;
      --text-secondary: #6b7280;
      --text-muted: #9ca3af;
      --border-color: #e5e7eb;
      --border-light: #f3f4f6;
      --bg-subtle: #f9fafb;
      --bg-white: #ffffff;

      --status-active: #059669;
      --status-active-bg: #d1fae5;
      --status-pending: #d97706;
      --status-pending-bg: #fef3c7;
      --status-sold: #dc2626;
      --status-sold-bg: #fee2e2;

      --font-body: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      --font-display: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    }

    /* ============================================
       PRINT STYLES
       ============================================ */
    @page { size: letter; margin: 0; }

    @media print {
      body {
        -webkit-print-color-adjust: exact !important;
        print-color-adjust: exact !important;
        background: white !important;
      }
      .report-page {
        box-shadow: none !important;
        margin: 0 !important;
        page-break-after: always;
        page-break-inside: avoid;
      }
    }

    /* ============================================
       BASE STYLES
       ============================================ */
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: var(--font-body);
      background: white;
      color: var(--text-primary);
      line-height: 1.4;
      -webkit-font-smoothing: antialiased;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    /* ============================================
       REPORT PAGE SHELL
       ============================================ */
    .report-page {
      width: 8.5in;
      height: 11in;
      background: var(--bg-white);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* ============================================
       HEADER
       ============================================ */
    .report-header {
      background: var(--header-bg);
      padding: 12px 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .report-header .title-block h1 {
      color: white;
      font-size: 17px;
      font-weight: 600;
      letter-spacing: -0.01em;
    }

    .report-header .title-block h1 span {
      font-weight: 400;
    }

    .report-header .title-block .meta {
      color: var(--accent-on-dark);
      font-size: 10px;
      margin-top: 2px;
    }

    .report-header .metric-block {
      text-align: right;
    }

    .report-header .metric-block .value {
      color: white;
      font-size: 22px;
      font-weight: 600;
      font-family: Georgia, serif;
      letter-spacing: -0.02em;
    }

    .report-header .metric-block .label {
      color: var(--accent-on-dark);
      font-size: 10px;
    }

    /* ============================================
       CONTENT ZONE
       ============================================ */
    .content-zone {
      flex: 1;
      padding: 14px 18px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      overflow: hidden;
    }

    /* ============================================
       AGENT FOOTER
       ============================================ */
    .agent-footer {
      padding: 12px 20px;
      border-top: 1px solid var(--border-color);
      background: var(--bg-subtle);
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .agent-footer .agent-photo {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: linear-gradient(135deg, #9ca3af 0%, #6b7280 100%);
      flex-shrink: 0;
      overflow: hidden;
    }

    .agent-footer .agent-info {
      flex: 1;
      min-width: 0;
    }

    .agent-footer .agent-info .name {
      font-size: 13px;
      font-weight: 600;
      color: var(--text-primary);
    }

    .agent-footer .agent-info .title {
      font-size: 10px;
      color: var(--text-secondary);
    }

    .agent-footer .contact-info {
      text-align: right;
      font-size: 10px;
      color: var(--text-secondary);
    }

    .agent-footer .company-info {
      padding-left: 12px;
      border-left: 1px solid var(--border-color);
    }

    .agent-footer .company-info .company-name {
      font-size: 11px;
      font-weight: 500;
      color: var(--text-primary);
    }

    .agent-footer .company-info .company-url {
      font-size: 10px;
      color: var(--text-secondary);
    }

    /* ============================================
       POWERED BY FOOTER
       ============================================ */
    .powered-by {
      padding: 6px;
      text-align: center;
      border-top: 1px solid var(--border-light);
    }

    .powered-by p {
      font-size: 9px;
      color: var(--text-muted);
    }

    /* ============================================
       GALLERY LAYOUT (Layout A)
       ============================================ */
    .gallery-grid {
      flex: 1;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }

    .listing-card {
      display: flex;
      flex-direction: column;
    }

    .listing-card .photo {
      aspect-ratio: 3/2.4;
      background: linear-gradient(135deg, #d1d5db 0%, #9ca3af 100%);
      border-radius: 4px;
      position: relative;
      overflow: hidden;
      flex: 1;
    }

    .listing-card .photo .badge {
      position: absolute;
      top: 5px;
      left: 5px;
      font-size: 7px;
      font-weight: 600;
      padding: 2px 5px;
      border-radius: 2px;
      text-transform: uppercase;
      z-index: 1;
    }

    .listing-card .photo .badge.featured {
      background: #f59e0b;
      color: white;
    }

    .listing-card .photo .badge.time {
      background: var(--accent-color);
      color: white;
    }

    .listing-card .photo .price-overlay {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 100%);
      padding: 8px;
    }

    .listing-card .photo .price-overlay .price {
      font-size: 13px;
      font-weight: 600;
      font-family: Georgia, serif;
      color: white;
    }

    .listing-card .details {
      padding-top: 6px;
    }

    .listing-card .details .address {
      font-size: 11px;
      font-weight: 500;
      color: var(--text-primary);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      line-height: 1.2;
    }

    .listing-card .details .location {
      font-size: 9px;
      color: var(--text-secondary);
    }

    .listing-card .details .price-specs {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-top: 2px;
    }

    .listing-card .details .price-specs .price {
      font-size: 13px;
      font-weight: 600;
      font-family: Georgia, serif;
      color: var(--primary-color);
    }

    .listing-card .details .price-specs .specs {
      font-size: 9px;
      color: var(--text-secondary);
    }

    /* ============================================
       MARKET SNAPSHOT (Layout B)
       ============================================ */
    .snapshot-top {
      display: flex;
      gap: 10px;
    }

    .hero-metric {
      width: 110px;
      flex-shrink: 0;
      background: linear-gradient(135deg, var(--primary-color) 0%, #1e3a5f 100%);
      border-radius: 6px;
      padding: 10px;
      text-align: center;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .hero-metric .value {
      font-size: 22px;
      font-weight: 700;
      font-family: Georgia, serif;
      color: white;
      letter-spacing: -0.02em;
    }

    .hero-metric .label {
      font-size: 9px;
      color: var(--accent-on-dark);
      margin-top: 1px;
    }

    .hero-metric .change {
      font-size: 9px;
      color: #5eead4;
    }

    .ai-insight {
      flex: 1;
      background: var(--accent-light);
      border: 1px solid #99f6e4;
      border-radius: 6px;
      padding: 10px;
    }

    .ai-insight .insight-label {
      font-size: 8px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--accent-on-light);
      margin-bottom: 2px;
    }

    .ai-insight p {
      font-size: 10px;
      color: var(--text-primary);
      line-height: 1.45;
    }

    .photo-grid-4 {
      flex: 1;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
    }

    .photo-grid-4 .photo-item {
      aspect-ratio: 3/4;
      background: linear-gradient(135deg, #d1d5db 0%, #9ca3af 100%);
      border-radius: 4px;
      position: relative;
      overflow: hidden;
    }

    .photo-grid-4 .photo-item .overlay {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 100%);
      padding: 10px;
    }

    .photo-grid-4 .photo-item .overlay .addr {
      font-size: 10px;
      font-weight: 500;
      color: white;
      line-height: 1.2;
    }

    .photo-grid-4 .photo-item .overlay .price {
      font-size: 11px;
      font-weight: 600;
      font-family: Georgia, serif;
      color: rgba(255,255,255,0.95);
    }

    .photo-grid-4 .photo-item .overlay .status {
      font-size: 7px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: rgba(255,255,255,0.7);
    }

    .stats-bar {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 6px;
    }

    .stats-bar .stat {
      background: var(--bg-subtle);
      border: 1px solid var(--border-light);
      border-radius: 4px;
      padding: 6px;
      text-align: center;
    }

    .stats-bar .stat .value {
      font-size: 14px;
      font-weight: 600;
      font-family: Georgia, serif;
      color: var(--primary-color);
    }

    .stats-bar .stat .label {
      font-size: 8px;
      color: var(--text-secondary);
    }

    .quick-take {
      background: var(--accent-light);
      border: 1px solid #99f6e4;
      border-radius: 4px;
      padding: 8px 10px;
    }

    .quick-take .qt-label {
      font-size: 8px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--accent-on-light);
      margin-bottom: 2px;
    }

    .quick-take p {
      font-size: 10px;
      color: var(--text-primary);
      line-height: 1.4;
    }

    /* ============================================
       CLOSED / INVENTORY (Layout C)
       ============================================ */
    .ci-top {
      display: flex;
      gap: 10px;
    }

    .ci-hero {
      background: linear-gradient(135deg, var(--primary-color) 0%, #1e3a5f 100%);
      border-radius: 6px;
      padding: 10px;
      text-align: center;
      display: flex;
      flex-direction: column;
      justify-content: center;
      aspect-ratio: 3/2.5;
    }

    .ci-hero .value {
      font-size: 28px;
      font-weight: 700;
      font-family: Georgia, serif;
      color: white;
    }

    .ci-hero .label {
      font-size: 9px;
      color: var(--accent-on-dark);
    }

    .ci-photo-grid {
      flex: 1;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 6px;
    }

    .ci-photo-grid .photo {
      aspect-ratio: 3/2.5;
      background: linear-gradient(135deg, #d1d5db 0%, #9ca3af 100%);
      border-radius: 3px;
      position: relative;
      overflow: hidden;
    }

    .ci-photo-grid .photo .status-badge {
      position: absolute;
      top: 4px;
      left: 4px;
      font-size: 6px;
      font-weight: 600;
      padding: 2px 4px;
      border-radius: 2px;
      text-transform: uppercase;
    }

    .ci-photo-grid .photo .status-badge.active { background: var(--status-active); color: white; }
    .ci-photo-grid .photo .status-badge.pending { background: var(--status-pending); color: white; }
    .ci-photo-grid .photo .status-badge.sold { background: var(--status-sold); color: white; }
    .ci-photo-grid .photo .status-badge.closed { background: var(--status-sold); color: white; }

    .data-table {
      flex: 1;
      overflow: hidden;
    }

    .data-table table {
      width: 100%;
      border-collapse: collapse;
      font-size: 9px;
    }

    .data-table th {
      text-align: left;
      padding: 4px 3px;
      font-weight: 500;
      color: var(--text-secondary);
      border-bottom: 1px solid var(--border-color);
    }

    .data-table th.center { text-align: center; }
    .data-table th.right { text-align: right; }

    .data-table td {
      padding: 4px 3px;
      border-bottom: 1px solid var(--border-light);
      color: var(--text-primary);
    }

    .data-table td.center { text-align: center; color: var(--text-secondary); }
    .data-table td.right { text-align: right; }
    .data-table td.price {
      font-weight: 500;
      color: var(--primary-color);
    }

    .inline-badge {
      display: inline-block;
      font-size: 7px;
      font-weight: 500;
      padding: 2px 5px;
      border-radius: 2px;
    }

    .inline-badge.active { background: var(--status-active-bg); color: var(--status-active); }
    .inline-badge.pending { background: var(--status-pending-bg); color: var(--status-pending); }
    .inline-badge.sold { background: var(--status-sold-bg); color: var(--status-sold); }
    .inline-badge.closed { background: var(--status-sold-bg); color: var(--status-sold); }

    .stats-bar-sm {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 5px;
    }

    .stats-bar-sm .stat {
      background: var(--bg-subtle);
      border: 1px solid var(--border-light);
      border-radius: 3px;
      padding: 5px;
      text-align: center;
    }

    .stats-bar-sm .stat .value {
      font-size: 12px;
      font-weight: 600;
      color: var(--primary-color);
    }

    .stats-bar-sm .stat .label {
      font-size: 7px;
      color: var(--text-secondary);
    }

    /* ============================================
       ANALYTICS (Layout D)
       ============================================ */
    .analytics-top {
      display: flex;
      gap: 8px;
    }

    .analytics-hero {
      width: 90px;
      flex-shrink: 0;
      background: linear-gradient(135deg, var(--primary-color) 0%, #1e3a5f 100%);
      border-radius: 6px;
      padding: 10px;
      text-align: center;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .analytics-hero .value {
      font-size: 20px;
      font-weight: 700;
      font-family: Georgia, serif;
      color: white;
    }

    .analytics-hero .label {
      font-size: 8px;
      color: var(--accent-on-dark);
    }

    .stat-cards-grid {
      flex: 1;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 5px;
    }

    .stat-cards-grid .stat-card {
      background: var(--bg-subtle);
      border: 1px solid var(--border-light);
      border-radius: 4px;
      padding: 6px 4px;
      text-align: center;
    }

    .stat-cards-grid .stat-card .value {
      font-size: 14px;
      font-weight: 600;
      font-family: Georgia, serif;
      color: var(--primary-color);
    }

    .stat-cards-grid .stat-card .label {
      font-size: 7px;
      color: var(--text-secondary);
      line-height: 1.2;
      margin-top: 1px;
    }

    .listing-rows {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .listing-row {
      display: flex;
      align-items: stretch;
      gap: 12px;
      background: var(--bg-subtle);
      border: 1px solid var(--border-light);
      border-radius: 4px;
      overflow: hidden;
    }

    .listing-row .thumb {
      width: 120px;
      aspect-ratio: 4/3;
      background: linear-gradient(135deg, #d1d5db 0%, #9ca3af 100%);
      flex-shrink: 0;
      position: relative;
    }

    .listing-row .thumb .status-badge {
      position: absolute;
      bottom: 4px;
      left: 4px;
      font-size: 7px;
      font-weight: 600;
      padding: 2px 5px;
      border-radius: 2px;
    }

    .listing-row .thumb .status-badge.active { background: var(--status-active-bg); color: var(--status-active); }
    .listing-row .thumb .status-badge.pending { background: var(--status-pending-bg); color: var(--status-pending); }

    .listing-row .info {
      flex: 1;
      min-width: 0;
      padding: 8px 0;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .listing-row .info .addr {
      font-size: 12px;
      font-weight: 500;
      color: var(--text-primary);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .listing-row .info .city {
      font-size: 9px;
      color: var(--text-secondary);
    }

    .listing-row .info .specs {
      font-size: 9px;
      color: var(--text-secondary);
      margin-top: 2px;
    }

    .listing-row .price-block {
      text-align: right;
      padding-right: 12px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .listing-row .price-block .price {
      font-size: 16px;
      font-weight: 600;
      font-family: Georgia, serif;
      color: var(--primary-color);
    }

    /* ============================================
       THEME OVERRIDES (injected by child template)
       ============================================ */
    {% block theme_styles %}{% endblock %}
  </style>
</head>
<body>
  <div class="report-page">
    {{ macros.report_header(header, stats, report_type) }}

    <div class="content-zone">
      {% block content %}
        {% if layout == "gallery" %}
          {{ macros.gallery_layout(header, listings, stats, report_type, agent) }}
        {% elif layout == "market_narrative" %}
          {{ macros.market_narrative_layout(header, listings, stats, ai_insights, agent) }}
        {% elif layout == "closed_inventory" %}
          {{ macros.closed_inventory_layout(header, listings, stats, report_type, agent, ai_insights) }}
        {% elif layout == "analytics" %}
          {{ macros.analytics_layout(header, listings, stats, price_bands, agent, ai_insights, report_type) }}
        {% else %}
          {{ macros.gallery_layout(header, listings, stats, report_type, agent) }}
        {% endif %}
      {% endblock %}
    </div>

    {{ macros.agent_footer(agent) }}
    {{ macros.powered_footer() }}
  </div>

  {# Force font rendering before PDF capture #}
  <div style="position:absolute;left:-9999px;top:-9999px;opacity:0;pointer-events:none;" aria-hidden="true">
    <span style="font-family:var(--font-display);font-weight:400;">.</span>
    <span style="font-family:var(--font-display);font-weight:600;">.</span>
    <span style="font-family:var(--font-display);font-weight:700;">.</span>
    <span style="font-family:var(--font-display);font-weight:800;">.</span>
    <span style="font-family:var(--font-body);font-weight:400;">.</span>
    <span style="font-family:var(--font-body);font-weight:500;">.</span>
    <span style="font-family:var(--font-body);font-weight:600;">.</span>
    <span style="font-family:var(--font-body);font-weight:700;">.</span>
  </div>
  <div aria-hidden="true" style="position:absolute;left:-9999px;top:0;opacity:0;font-size:1px;line-height:1;pointer-events:none;">
    <span style="font-family:'Inter',sans-serif">.</span>
    <span style="font-family:'Playfair Display',serif">.</span>
    <span style="font-family:'Montserrat',sans-serif">.</span>
    <span style="font-family:'Libre Baskerville',serif">.</span>
    <span style="font-family:'Cormorant Garamond',serif">.</span>
    <span style="font-family:'DM Sans',sans-serif">.</span>
    <span style="font-family:'Space Grotesk',sans-serif">.</span>
    <span style="font-family:'Georgia',serif">.</span>
  </div>
</body>
</html>
